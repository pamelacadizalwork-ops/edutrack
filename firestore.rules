rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Classes - allow public read so students can look up join codes before login
    match /classes/{classId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        resource.data.teacherId == request.auth.uid;
    }

    // Students can create their own record on signup
    match /students/{studentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == studentId;
      allow update: if request.auth != null &&
        (request.auth.uid == studentId ||
         resource.data.teacherId == request.auth.uid);
      allow delete: if request.auth != null &&
        resource.data.teacherId == request.auth.uid;
    }

    // Attendance - authenticated users only
    match /attendance/{recordId} {
      allow read, write: if request.auth != null;
    }

    // QR sessions - authenticated users only
    match /qrSessions/{sessionId} {
      allow read, write: if request.auth != null;
    }
  }
}
