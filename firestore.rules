rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Teachers can manage their own classes
    // Anyone authenticated can read classes (for join code lookup)
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        resource.data.teacherId == request.auth.uid;
    }

    // Students can create their own record on signup
    // Teachers can read/update/delete students in their classes
    match /students/{studentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == studentId;
      allow update: if request.auth != null &&
        (request.auth.uid == studentId ||
         resource.data.teacherId == request.auth.uid);
      allow delete: if request.auth != null &&
        resource.data.teacherId == request.auth.uid;
    }

    // Teachers can write attendance; students can read their own
    match /attendance/{recordId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // QR sessions - authenticated users only
    match /qrSessions/{sessionId} {
      allow read, write: if request.auth != null;
    }
  }
}
